# Model weights.
# Curated checkpoints in data/models/ are tracked with Git LFS so a fresh clone
# can run trained profiles. Ad-hoc checkpoints elsewhere remain ignored.
*.pt
*.pth
!data/models/**/*.pt
!data/models/**/*.pth

# Training datasets (can be rebuilt from manifest)
data/training/airborne_yolo_v1/
data/training/airborne_yolo_v2/
data/training/aod4_only_test/
data/training/local_sparse_gt_yolo/
data/training/anti_uav300_smoke_test/
data/training/prototypes/
data/training/previews/
data/training/validation_slices/
data/training/raw_cache/
data/training/converted/
data/training/airborne_stage*/
data/training/airborne_yolo_v3_finetune_quick/
data/training/.ultralytics/

# Training outputs
runs/
data/outputs/

# Raw external datasets stay local. Keep this root-anchored so scripts/datasets/
# stays visible to Git on case-insensitive Windows filesystems.
/DATASETS/

# Local training logs (UTF-16 PowerShell tee output, can grow into tens of MB)
data/training/*.log
data/training/logs/
data/training/runs/

# Video files (large, use separately)
data/videos/
*.mp4
*.MP4
*.avi
*.mov

# Python cache
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.tmp_pytest/
.pytest_tmp_run/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
.claude/
Ultralytics/

# Environment
.venv/
.venv_train/
venv/

# Local raw datasets and generated training sets
data/raw/
data/training/yolov26_lrdd_no_bird/
